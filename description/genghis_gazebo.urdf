      <origin xyz="-0.165 0 0.027" rpy="0 0 0"/>
      <geometry><box size="0.01 0.085 0.01"/></geometry>
      <material name="alu"/>
    </visual>
    <visual>
      <origin xyz="-0.165 0 -0.023" rpy="0 0 0"/>
      <geometry><box size="0.01 0.085 0.01"/></geometry>
      <material name="alu"/>
    </visual>
    <collision>
      <origin xyz="0.035 0 0.002" rpy="0 0 0"/>
      <geometry><box size="0.4 0.085 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.035 0.0 0.002" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="5.412500e-04" ixy="0" ixz="0" iyy="8.180000e-03" iyz="0" izz="8.361250e-03"/>
    </inertial>
  </link>

  <!-- ===== gamba FL (L, front) ===== -->
  <joint name="FL_swing" type="revolute">
    <parent link="base_link"/>
    <child link="FL_shoulder"/>
    <origin xyz="0.165 0.0375 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 -1.0"/>
    <limit lower="-0.9" upper="0.9" effort="1.5" velocity="6.0"/>
