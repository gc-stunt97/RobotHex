<?xml version="1.0"?>
<!-- GENERATO da description/gen_urdf.py — NON modificare a mano. -->
<!-- Variante GAZEBO: inerzie reali + attrito piedi + ros2_control. -->
<robot name="genghis">
  <material name="alu"><color rgba="0.75 0.75 0.78 1"/></material>
  <material name="servo"><color rgba="0.12 0.12 0.12 1"/></material>
  <material name="leg"><color rgba="0.85 0.85 0.88 1"/></material>
  <material name="foot"><color rgba="0.15 0.15 0.15 1"/></material>
  <material name="head"><color rgba="0.10 0.35 0.85 1"/></material>
  <material name="cam"><color rgba="0.05 0.05 0.05 1"/></material>
  <link name="base_link">
    <visual>
      <origin xyz="0.035 0 -0.023" rpy="0 0 0"/>
      <geometry><box size="0.4 0.01 0.01"/></geometry>
      <material name="alu"/>
    </visual>
    <visual>
      <origin xyz="0.035 0 0.027" rpy="0 0 0"/>
      <geometry><box size="0.4 0.01 0.01"/></geometry>
      <material name="alu"/>
    </visual>
    <visual>
      <origin xyz="0.165 0 0.027" rpy="0 0 0"/>
      <geometry><box size="0.01 0.085 0.01"/></geometry>
      <material name="alu"/>
    </visual>
    <visual>
      <origin xyz="0.165 0 -0.023" rpy="0 0 0"/>
      <geometry><box size="0.01 0.085 0.01"/></geometry>
      <material name="alu"/>
    </visual>
